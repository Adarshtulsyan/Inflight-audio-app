<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Subtle Flight Motif (Top Right) -->
    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="-20dp"
        android:layout_marginEnd="-20dp"
        android:alpha="0.05"
        android:rotation="45"
        android:src="@drawable/ic_airplane"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Screen 1: Welcome Intro -->
    <LinearLayout
        android:id="@+id/welcomeScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:visibility="visible">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="32dp"
            android:alpha="0.9"
            android:src="@drawable/dadi" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:letterSpacing="0.2"
            android:text="@string/welcome_title"
            android:textAllCaps="true"
            android:textColor="@color/gold"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:lineSpacingExtra="8dp"
            android:text="@string/welcome_message"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.1"
                android:text="@string/organized_by_prefix"
                android:textAllCaps="true"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:letterSpacing="0.3"
                android:text="@string/marwari_samaj"
                android:textAllCaps="true"
                android:textColor="@color/gold"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/enterCabinBtn"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/btn_confirm_bg"
            android:text="@string/proceed_to_cabin"
            android:textAllCaps="true"
            android:textColor="@color/background"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Screen 2: Main Content (Hidden by default) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Premium Header -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="60dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/dadiImage"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="24dp"
                android:alpha="0.9"
                android:scaleType="centerInside"
                android:src="@drawable/dadi" />

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:letterSpacing="0.1"
                android:text="@string/title"
                android:textAllCaps="true"
                android:textColor="@color/gold"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingHorizontal="24dp" />

            <TextView
                android:id="@+id/subtitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.4"
                android:text="@string/subtitle"
                android:textAllCaps="true"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Content Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/mainCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            app:cardBackgroundColor="#121212"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toTopOf="@+id/downloadPrompt"
            app:layout_constraintTop_toBottomOf="@id/headerLayout">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_airplane"
                        android:tint="@color/gold_soft" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:text="FLIGHT MODE: SYNCED"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/statusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/earphone_row_bg_default"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="LIVE"
                        android:textColor="@color/gold"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="sans-serif-thin"
                    android:gravity="center"
                    android:text="@string/checking_audio"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />

                <LinearLayout
                    android:id="@+id/playerLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <FrameLayout
                        android:id="@+id/progressTrack"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="#222222">
                        <View
                            android:id="@+id/progressFill"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="@color/gold" />
                    </FrameLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/currentTimeText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="monospace"
                            android:text="0:00"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/remainingTimeText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="monospace"
                            android:gravity="end"
                            android:text="-0:00"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="24dp"
                    android:background="@color/divider" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:id="@+id/earphoneRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/earphoneText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center"
                            android:text="@string/earphone_prompt"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                        <Button
                            android:id="@+id/confirmEarphonesBtn"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/btn_confirm_bg"
                            android:text="@string/confirm_earphones"
                            android:textAllCaps="true"
                            android:textColor="@color/background"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/playbackControls"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:visibility="gone">
                        <Button
                            android:id="@+id/startBtn"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_start_bg"
                            android:text="@string/start"
                            android:textAllCaps="true"
                            android:textColor="@color/background"
                            android:textStyle="bold" />
                        <Button
                            android:id="@+id/stopBtn"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_stop_bg"
                            android:text="@string/stop"
                            android:textAllCaps="true"
                            android:textColor="@color/text_primary"
                            android:enabled="false" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/downloadPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="@string/audio_unavailable_msg"
            android:textColor="@color/btn_stop_text"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
