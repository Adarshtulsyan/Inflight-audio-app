<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="56dp"
        android:paddingBottom="56dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Dadi image -->
        <ImageView
            android:id="@+id/dadiImage"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_marginBottom="20dp"
            android:contentDescription="Dadi"
            android:scaleType="centerInside"
            android:src="@drawable/dadi" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="serif"
            android:letterSpacing="0.12"
            android:text="@string/title"
            android:textAllCaps="true"
            android:textColor="@color/gold"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:letterSpacing="0.2"
            android:text="@string/subtitle"
            android:textAllCaps="true"
            android:textColor="@color/text_subtitle"
            android:textSize="12sp" />

        <!-- Divider -->
        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:layout_marginBottom="28dp"
            android:background="@color/divider" />

        <!-- Earphone status row -->
        <LinearLayout
            android:id="@+id/earphoneRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:background="@drawable/earphone_row_bg_default"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <View
                android:id="@+id/earphoneDot"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/dot_default" />

            <TextView
                android:id="@+id/earphoneText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.03"
                android:text="@string/earphone_checking"
                android:textColor="@color/text_earphone"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Confirm earphones button -->
        <Button
            android:id="@+id/confirmEarphonesBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="@drawable/btn_confirm_bg"
            android:letterSpacing="0.07"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:stateListAnimator="@null"
            android:text="@string/confirm_earphones"
            android:textAllCaps="false"
            android:textColor="@color/btn_confirm_text"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Start / Stop buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/startBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/btn_start_bg"
                android:enabled="false"
                android:letterSpacing="0.07"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:stateListAnimator="@null"
                android:text="@string/start"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <Button
                android:id="@+id/stopBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_stop_bg"
                android:enabled="false"
                android:letterSpacing="0.07"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:stateListAnimator="@null"
                android:text="@string/stop"
                android:textAllCaps="false"
                android:textColor="@color/btn_stop_text"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Status text -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="20dp"
            android:letterSpacing="0.07"
            android:text="@string/checking_audio"
            android:textColor="@color/text_status"
            android:textSize="13sp" />

        <!-- Player (progress bar + time) -->
        <LinearLayout
            android:id="@+id/playerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Progress track -->
            <FrameLayout
                android:id="@+id/progressTrack"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginBottom="10dp"
                android:background="@color/progress_track">

                <View
                    android:id="@+id/progressFill"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/progress_gradient" />

            </FrameLayout>

            <!-- Time display -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/currentTimeText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.07"
                    android:text="0:00"
                    android:textColor="@color/text_time"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/remainingTimeText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:letterSpacing="0.07"
                    android:text="-0:00"
                    android:textColor="@color/text_time"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Audio unavailable message -->
        <LinearLayout
            android:id="@+id/downloadPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/download_prompt_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lineSpacingMultiplier="1.7"
                android:text="@string/audio_unavailable_msg"
                android:textColor="@color/text_earphone"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Debug Log Console -->
        <TextView
            android:id="@+id/debugLogText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="#1A000000"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:text="System logs will appear here..."
            android:textColor="#80000000"
            android:textSize="10sp" />

    </LinearLayout>

</ScrollView>
